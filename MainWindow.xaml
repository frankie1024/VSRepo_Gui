<ui:FluentWindow x:Class="vsrepo_Gui.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:models="clr-namespace:vsrepo_Gui.Models"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="vsrepo_Gui"
                 Width="1560"
                 Height="980"
                 MinWidth="1280"
                 MinHeight="820"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="vsrepo_Gui" />

        <Grid Grid.Row="1" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationView x:Name="RootNavigationView"
                               Grid.Column="0"
                               Margin="12,0,12,12"
                               PaneDisplayMode="Left"
                               IsPaneToggleVisible="False"
                               IsBackButtonVisible="Collapsed"
                               PaneTitle="vsrepo_Gui"
                               SelectionChanged="RootNavigationView_SelectionChanged">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem x:Name="PluginsNavigationItem" Content="Plugins" Tag="plugins">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="PuzzlePiece24" />
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.MenuItems>
                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem x:Name="SettingsNavigationItem" Content="Settings" Tag="settings">
                        <ui:NavigationViewItem.Icon>
                            <ui:SymbolIcon Symbol="Settings24" />
                        </ui:NavigationViewItem.Icon>
                    </ui:NavigationViewItem>
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>

            <Grid Grid.Column="1" Margin="0,0,20,20">
                <Grid x:Name="PluginsView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="230" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,8,0,16">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Plugin Library" />
                            <TextBlock Style="{StaticResource SectionSubtitleTextBlockStyle}" Text="Install, upgrade and remove VapourSynth plugins from one focused workspace." />
                        </StackPanel>
                        <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Top">
                            <ui:Button x:Name="RefreshButton" Margin="0,0,8,0" Appearance="Secondary" Click="RefreshButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,8,0" />
                                    <TextBlock Text="Refresh" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button x:Name="UpdateDefinitionsButton" Margin="0,0,8,0" Appearance="Secondary" Click="UpdateDefinitionsButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,8,0" />
                                    <TextBlock Text="Update Definitions" />
                                </StackPanel>
                            </ui:Button>
                            <ui:Button x:Name="UpgradeAllButton" Appearance="Primary" Click="UpgradeAllButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowUp24" Margin="0,0,8,0" />
                                    <TextBlock Text="Upgrade All" />
                                </StackPanel>
                            </ui:Button>
                        </WrapPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,16">
                            <ui:Card Margin="0,0,10,0" Padding="16"><StackPanel><TextBlock Foreground="{StaticResource StatUpdatesBrush}" Text="Updates" /><TextBlock x:Name="UpdatesCountTextBlock" Margin="0,6,0,0" FontSize="26" FontWeight="SemiBold" Text="0" /></StackPanel></ui:Card>
                            <ui:Card Margin="10,0,10,0" Padding="16"><StackPanel><TextBlock Foreground="{StaticResource StatInstalledBrush}" Text="Installed" /><TextBlock x:Name="InstalledCountTextBlock" Margin="0,6,0,0" FontSize="26" FontWeight="SemiBold" Text="0" /></StackPanel></ui:Card>
                            <ui:Card Margin="10,0,10,0" Padding="16"><StackPanel><TextBlock Foreground="{StaticResource StatPendingBrush}" Text="Not Installed" /><TextBlock x:Name="NotInstalledCountTextBlock" Margin="0,6,0,0" FontSize="26" FontWeight="SemiBold" Text="0" /></StackPanel></ui:Card>
                            <ui:Card Margin="10,0,0,0" Padding="16"><StackPanel><TextBlock Foreground="{StaticResource StatUnknownBrush}" Text="Unknown" /><TextBlock x:Name="UnknownCountTextBlock" Margin="0,6,0,0" FontSize="26" FontWeight="SemiBold" Text="0" /></StackPanel></ui:Card>
                        </UniformGrid>

                        <ui:Card Grid.Row="1" Padding="16">
                            <WrapPanel ItemHeight="38">
                                <TextBlock Margin="0,8,10,0" Text="Target" />
                                <ComboBox x:Name="TargetComboBox" Width="120" Margin="0,0,18,0" SelectionChanged="TargetComboBox_SelectionChanged" />
                                <TextBlock Margin="0,8,10,0" Text="Status" />
                                <ComboBox x:Name="StatusFilterComboBox" Width="170" Margin="0,0,18,0" SelectionChanged="FilterChanged" />
                                <TextBlock Margin="0,8,10,0" Text="Category" />
                                <ComboBox x:Name="CategoryFilterComboBox" Width="220" Margin="0,0,18,0" SelectionChanged="FilterChanged" />
                                <TextBlock Margin="0,8,10,0" Text="Search" />
                                <ui:TextBox x:Name="SearchTextBox" Width="320" Margin="0,0,0,0" PlaceholderText="Name, namespace, identifier..." TextChanged="SearchTextBox_TextChanged" />
                            </WrapPanel>
                        </ui:Card>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.25*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1.15*" />
                        </Grid.ColumnDefinitions>

                        <ui:Card Grid.Column="0" Padding="8">
                            <DataGrid x:Name="PackagesGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      SelectionChanged="PackagesGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Action" Width="122">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ui:Button Tag="{Binding}" Click="PackageAction_Click">
                                                    <TextBlock Text="{Binding ActionText}" />
                                                </ui:Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200" />
                                    <DataGridTextColumn Header="Namespace / Module" Binding="{Binding NamespaceOrModule}" Width="170" />
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="118" />
                                    <DataGridTextColumn Header="Installed" Binding="{Binding InstalledVersion}" Width="106" />
                                    <DataGridTextColumn Header="Latest" Binding="{Binding LatestVersion}" Width="106" />
                                    <DataGridTextColumn Header="Published" Binding="{Binding LatestPublishedText}" Width="120" />
                                    <DataGridTemplateColumn Header="State" Width="152">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,5" MinWidth="120" CornerRadius="8">
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeBorderStyle}">
                                                            <Setter Property="Background" Value="{StaticResource StatUpdatesBackgroundBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:PackageInstallState.Installed}"><Setter Property="Background" Value="{StaticResource StatInstalledBackgroundBrush}" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:PackageInstallState.NotInstalled}"><Setter Property="Background" Value="{StaticResource StatUpdatesBackgroundBrush}" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:PackageInstallState.UpdateAvailable}"><Setter Property="Background" Value="{StaticResource StatPendingBackgroundBrush}" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding State}" Value="{x:Static models:PackageInstallState.InstalledUnknown}"><Setter Property="Background" Value="{StaticResource StatUnknownBackgroundBrush}" /></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding StateText}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Identifier" Binding="{Binding Identifier}" Width="190" />
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </ui:Card>

                        <ui:Card Grid.Column="2" Padding="20">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock x:Name="DetailNameTextBlock" FontSize="30" FontWeight="SemiBold" Text="Select a package" />
                                            <TextBlock x:Name="DetailNamespaceTextBlock" Margin="0,6,0,0" Opacity="0.75" Text="Namespace / module" />
                                        </StackPanel>
                                        <Border x:Name="DetailStateBorder" Style="{StaticResource StatusBadgeBorderStyle}" DockPanel.Dock="Right">
                                            <TextBlock x:Name="DetailStateTextBlock" Text="Idle" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                        </Border>
                                    </DockPanel>
                                    <TextBlock x:Name="DetailDescriptionTextBlock" Margin="0,18,0,0" TextWrapping="Wrap" Opacity="0.8" Text="Package details will appear here." />

                                    <UniformGrid Margin="0,18,0,0" Columns="2">
                                        <ui:Card Margin="0,0,10,10" Padding="14"><StackPanel><TextBlock Opacity="0.7" Text="Identifier" /><TextBlock x:Name="DetailIdentifierTextBlock" Margin="0,6,0,0" FontWeight="SemiBold" Text="-" /></StackPanel></ui:Card>
                                        <ui:Card Margin="10,0,0,10" Padding="14"><StackPanel><TextBlock Opacity="0.7" Text="Category" /><TextBlock x:Name="DetailCategoryTextBlock" Margin="0,6,0,0" FontWeight="SemiBold" Text="-" /></StackPanel></ui:Card>
                                        <ui:Card Margin="0,0,10,10" Padding="14"><StackPanel><TextBlock Opacity="0.7" Text="Installed" /><TextBlock x:Name="DetailInstalledTextBlock" Margin="0,6,0,0" FontWeight="SemiBold" Text="-" /></StackPanel></ui:Card>
                                        <ui:Card Margin="10,0,0,10" Padding="14"><StackPanel><TextBlock Opacity="0.7" Text="Latest" /><TextBlock x:Name="DetailLatestTextBlock" Margin="0,6,0,0" FontWeight="SemiBold" Text="-" /></StackPanel></ui:Card>
                                        <ui:Card Margin="0,0,10,10" Padding="14"><StackPanel><TextBlock Opacity="0.7" Text="Type" /><TextBlock x:Name="DetailTypeTextBlock" Margin="0,6,0,0" FontWeight="SemiBold" Text="-" /></StackPanel></ui:Card>
                                        <ui:Card Margin="10,0,0,10" Padding="14"><StackPanel><TextBlock Opacity="0.7" Text="VSRepo Published" /><TextBlock x:Name="DetailPublishedTextBlock" Margin="0,6,0,0" FontWeight="SemiBold" Text="-" /></StackPanel></ui:Card>
                                    </UniformGrid>

                                    <ui:Card Margin="0,8,0,0" Padding="14">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left" FontSize="15" FontWeight="SemiBold" Text="GitHub Upstream" />
                                                <ui:Button x:Name="RefreshGitHubButton" DockPanel.Dock="Right" Appearance="Secondary" Click="RefreshGitHubButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,8,0" />
                                                        <TextBlock Text="Refresh GitHub" />
                                                    </StackPanel>
                                                </ui:Button>
                                            </DockPanel>
                                            <TextBlock x:Name="DetailGithubStatusTextBlock" Margin="0,10,0,0" Opacity="0.8" Text="No GitHub metadata loaded." />
                                            <TextBlock x:Name="DetailGithubTagTextBlock" Margin="0,8,0,0" FontWeight="SemiBold" Text="Latest release: -" />
                                            <TextBlock x:Name="DetailGithubUpdatedTextBlock" Margin="0,6,0,0" FontWeight="SemiBold" Text="Updated: -" />
                                        </StackPanel>
                                    </ui:Card>

                                    <ui:Card Margin="0,14,0,0" Padding="14">
                                        <StackPanel>
                                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="Dependencies" />
                                            <ItemsControl x:Name="DependenciesItemsControl" Margin="0,10,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,8" Padding="10,6" CornerRadius="8" Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                            <TextBlock Text="{Binding}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ui:Card>

                                    <WrapPanel Margin="0,18,0,0">
                                        <ui:Button x:Name="DetailActionButton" Margin="0,0,8,8" Appearance="Primary" Click="DetailActionButton_Click"><TextBlock Text="Run Action" /></ui:Button>
                                        <ui:Button x:Name="CopyIdentifierButton" Margin="0,0,8,8" Appearance="Secondary" Click="CopyIdentifierButton_Click"><TextBlock Text="Copy Identifier" /></ui:Button>
                                        <ui:Button x:Name="OpenWebsiteButton" Margin="0,0,8,8" Appearance="Secondary" Click="OpenWebsiteButton_Click"><TextBlock Text="Open Website" /></ui:Button>
                                        <ui:Button x:Name="OpenGitHubButton" Margin="0,0,8,8" Appearance="Secondary" Click="OpenGitHubButton_Click"><TextBlock Text="Open GitHub" /></ui:Button>
                                        <ui:Button x:Name="OpenDoom9Button" Margin="0,0,8,8" Appearance="Secondary" Click="OpenDoom9Button_Click"><TextBlock Text="Open Doom9" /></ui:Button>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </ui:Card>
                    </Grid>

                    <ui:Card Grid.Row="3" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" Text="Logs" />
                                <ui:Button DockPanel.Dock="Right" Appearance="Secondary" Click="OpenLogFolderButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="FolderOpen24" Margin="0,0,8,0" />
                                        <TextBlock Text="Open Log Folder" />
                                    </StackPanel>
                                </ui:Button>
                                <ui:Button DockPanel.Dock="Right" Margin="0,0,8,0" Appearance="Secondary" Click="ClearLogButton_Click">
                                    <TextBlock Text="Clear" />
                                </ui:Button>
                            </DockPanel>
                            <TextBox x:Name="LogTextBox" Grid.Row="1" Margin="0,14,0,0" FontFamily="Cascadia Mono" FontSize="12.5" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </ui:Card>
                </Grid>

                <Grid x:Name="SettingsView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,8,0,16">
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Settings" />
                        <TextBlock Style="{StaticResource SectionSubtitleTextBlockStyle}" Text="Interpreter, plugin paths and environment diagnostics are grouped here so Plugins stays focused on package management." />
                    </StackPanel>

                    <ui:Card Grid.Row="1" Padding="18" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,0" Text="Python" />
                            <ui:TextBox x:Name="PythonPathTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,12,0" PlaceholderText="Select python.exe" />
                            <ui:Button x:Name="BrowsePythonButton" Grid.Row="0" Grid.Column="2" Margin="0,0,8,0" Appearance="Secondary" Click="BrowsePythonButton_Click"><TextBlock Text="Browse" /></ui:Button>
                            <ui:Button x:Name="DetectPythonButton" Grid.Row="0" Grid.Column="3" Margin="0,0,8,0" Appearance="Secondary" Click="DetectPythonButton_Click"><TextBlock Text="Auto Detect" /></ui:Button>
                            <ui:Button x:Name="ProbeButton" Grid.Row="0" Grid.Column="4" Appearance="Primary" Click="ProbeButton_Click"><TextBlock Text="Probe" /></ui:Button>

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,22,12,0" Text="Status" />
                            <TextBlock x:Name="StatusTextBlock" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,22,0,0" TextWrapping="Wrap" />

                            <WrapPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,20,0,0" ItemHeight="38">
                                <TextBlock Margin="0,8,10,0" Text="Definitions" />
                                <TextBox x:Name="DefinitionsPathTextBox" Width="360" Margin="0,0,8,0" IsReadOnly="True" />
                                <ui:Button Appearance="Secondary" Margin="0,0,18,0" Click="OpenDefinitionsButton_Click"><TextBlock Text="Open" /></ui:Button>
                                <TextBlock Margin="0,8,10,0" Text="Binaries" />
                                <TextBox x:Name="BinariesPathTextBox" Width="360" Margin="0,0,8,0" IsReadOnly="True" />
                                <ui:Button Appearance="Secondary" Margin="0,0,18,0" Click="OpenBinariesButton_Click"><TextBlock Text="Open" /></ui:Button>
                                <TextBlock Margin="0,8,10,0" Text="Scripts" />
                                <TextBox x:Name="ScriptsPathTextBox" Width="360" Margin="0,0,8,0" IsReadOnly="True" />
                                <ui:Button Appearance="Secondary" Click="OpenScriptsButton_Click"><TextBlock Text="Open" /></ui:Button>
                            </WrapPanel>
                        </Grid>
                    </ui:Card>

                    <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,0">
                        <ui:Card Margin="0,0,10,0" Padding="18">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Recommended Flow" />
                                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Opacity="0.8" Text="1. Keep the interpreter stable here. 2. Return to Plugins for package work. 3. Only revisit Settings when switching environments or debugging path issues." />
                            </StackPanel>
                        </ui:Card>
                        <ui:Card Margin="10,0,0,0" Padding="18">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Page Intent" />
                                <TextBlock Margin="0,12,0,0" Opacity="0.8" TextWrapping="Wrap" Text="The plugin target selector stays on the Plugins page because it directly affects browsing and operations. Settings is reserved for interpreter and path configuration." />
                            </StackPanel>
                        </ui:Card>
                    </UniformGrid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
