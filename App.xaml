<Application x:Class="VSRepo_Gui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:VSRepo_Gui.Models"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="StatUpdatesBrush" Color="#0F6CBD" />
            <SolidColorBrush x:Key="StatUpdatesBackgroundBrush" Color="#DCEBFA" />
            <SolidColorBrush x:Key="StatInstalledBrush" Color="#0E8A16" />
            <SolidColorBrush x:Key="StatInstalledBackgroundBrush" Color="#DFF6DD" />
            <SolidColorBrush x:Key="StatPendingBrush" Color="#9D5D00" />
            <SolidColorBrush x:Key="StatPendingBackgroundBrush" Color="#FFF4CE" />
            <SolidColorBrush x:Key="StatUnknownBrush" Color="#C42B1C" />
            <SolidColorBrush x:Key="StatUnknownBackgroundBrush" Color="#FDE7E9" />

            <Style x:Key="SectionTitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,6" />
            </Style>

            <Style x:Key="SectionSubtitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="Opacity" Value="0.72" />
                <Setter Property="Margin" Value="0,0,0,14" />
            </Style>

            <Style x:Key="FieldLabelTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Opacity" Value="0.72" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="MinWidth" Value="120" />
            </Style>

            <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{StaticResource StatUpdatesBrush}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:PackageInstallState.Installed}">
                        <Setter Property="Foreground" Value="{StaticResource StatInstalledBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:PackageInstallState.NotInstalled}">
                        <Setter Property="Foreground" Value="{StaticResource StatUpdatesBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:PackageInstallState.UpdateAvailable}">
                        <Setter Property="Foreground" Value="{StaticResource StatPendingBrush}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding State}" Value="{x:Static models:PackageInstallState.InstalledUnknown}">
                        <Setter Property="Foreground" Value="{StaticResource StatUnknownBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ThemeModeOptionStyle" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="ThemeOptionBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThemeOptionBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ThemeOptionBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ThemeOptionBorder" Property="Opacity" Value="0.6" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GridCellTextStyle" TargetType="TextBlock">
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="StatusSummaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CardBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CardBorder" Property="Opacity" Value="0.92" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="CardBorder" Property="Opacity" Value="0.6" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Foreground" Value="#1F1F1F" />
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#B8B8B8" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="MinHeight" Value="42" />
                <Setter Property="MinWidth" Value="120" />
                <Setter Property="MaxDropDownHeight" Value="360" />
                <Setter Property="Padding" Value="14,0,40,0" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid SnapsToDevicePixels="True">
                                <Border x:Name="InputBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" />

                                <ContentPresenter x:Name="SelectionContent"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  IsHitTestVisible="False"
                                                  RecognizesAccessKey="True"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />

                                <Path x:Name="ArrowGlyph"
                                      Width="10"
                                      Height="6"
                                      Margin="0,0,14,0"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Data="M 0 0 L 5 6 L 10 0"
                                      Fill="Transparent"
                                      Stroke="#5F5F5F"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeThickness="1.6" />

                                <ToggleButton x:Name="DropDownToggle"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              ClickMode="Press"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       PopupAnimation="Fade"
                                       StaysOpen="False">
                                    <Border x:Name="PopupBorder"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            Margin="0,6,0,0"
                                            Padding="6"
                                            Background="#FFFFFF"
                                            BorderBrush="#CFCFCF"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            SnapsToDevicePixels="True">
                                        <ScrollViewer CanContentScroll="True"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="PopupBorder" Property="MinHeight" Value="42" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="InputBorder" Property="Background" Value="#F6F6F6" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="InputBorder" Property="BorderBrush" Value="#9A9A9A" />
                                </Trigger>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="InputBorder" Property="Background" Value="#F3F3F3" />
                                    <Setter TargetName="InputBorder" Property="BorderBrush" Value="#9A9A9A" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="InputBorder" Property="Opacity" Value="0.65" />
                                    <Setter TargetName="SelectionContent" Property="Opacity" Value="0.65" />
                                    <Setter TargetName="ArrowGlyph" Property="Opacity" Value="0.55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FluentComboBoxItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="#1F1F1F" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#EFEFEF" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#E6E6E6" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.65" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FluentDarkComboBoxItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="#F3F3F3" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#3B3B3B" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#4A4A4A" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.65" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FluentDarkComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Foreground" Value="#F3F3F3" />
                <Setter Property="Background" Value="#2F2F2F" />
                <Setter Property="BorderBrush" Value="#5A5A5A" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="MinHeight" Value="42" />
                <Setter Property="MinWidth" Value="120" />
                <Setter Property="MaxDropDownHeight" Value="360" />
                <Setter Property="Padding" Value="14,0,40,0" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid SnapsToDevicePixels="True">
                                <Border x:Name="InputBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" />

                                <ContentPresenter x:Name="SelectionContent"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  IsHitTestVisible="False"
                                                  RecognizesAccessKey="True"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />

                                <Path x:Name="ArrowGlyph"
                                      Width="10"
                                      Height="6"
                                      Margin="0,0,14,0"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Data="M 0 0 L 5 6 L 10 0"
                                      Fill="Transparent"
                                      Stroke="#D6D6D6"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeThickness="1.6" />

                                <ToggleButton x:Name="DropDownToggle"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              ClickMode="Press"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       PopupAnimation="Fade"
                                       StaysOpen="False">
                                    <Border x:Name="PopupBorder"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            Margin="0,6,0,0"
                                            Padding="6"
                                            Background="#242424"
                                            BorderBrush="#5A5A5A"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            SnapsToDevicePixels="True">
                                        <ScrollViewer CanContentScroll="True"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="HasItems" Value="False">
                                    <Setter TargetName="PopupBorder" Property="MinHeight" Value="42" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="InputBorder" Property="Background" Value="#383838" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="InputBorder" Property="BorderBrush" Value="#8A8A8A" />
                                </Trigger>
                                <Trigger Property="IsDropDownOpen" Value="True">
                                    <Setter TargetName="InputBorder" Property="Background" Value="#383838" />
                                    <Setter TargetName="InputBorder" Property="BorderBrush" Value="#8A8A8A" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="InputBorder" Property="Opacity" Value="0.65" />
                                    <Setter TargetName="SelectionContent" Property="Opacity" Value="0.65" />
                                    <Setter TargetName="ArrowGlyph" Property="Opacity" Value="0.55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FluentTextBoxStyle" TargetType="ui:TextBox">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="Background" Value="{DynamicResource ControlFillColorInputBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="MinHeight" Value="42" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="FluentDarkTextBoxStyle" TargetType="ui:TextBox" BasedOn="{StaticResource FluentTextBoxStyle}">
                <Setter Property="Foreground" Value="#F3F3F3" />
                <Setter Property="Background" Value="#2F2F2F" />
                <Setter Property="BorderBrush" Value="#5A5A5A" />
                <Setter Property="CaretBrush" Value="#F3F3F3" />
            </Style>

            <Style x:Key="FluentReadOnlyTextBoxStyle" TargetType="ui:TextBox" BasedOn="{StaticResource FluentTextBoxStyle}">
                <Setter Property="IsReadOnly" Value="True" />
            </Style>

            <Style x:Key="FluentDarkReadOnlyTextBoxStyle" TargetType="ui:TextBox" BasedOn="{StaticResource FluentDarkTextBoxStyle}">
                <Setter Property="IsReadOnly" Value="True" />
            </Style>

            <Style x:Key="LinkChipButtonStyle" TargetType="ui:Button">
                <Setter Property="Appearance" Value="Secondary" />
                <Setter Property="MinHeight" Value="38" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Margin" Value="0,0,10,10" />
                <Setter Property="Padding" Value="14,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

