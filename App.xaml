<Application x:Class="VSRepo_Gui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="StatUpdatesBrush" Color="#0F6CBD" />
            <SolidColorBrush x:Key="StatUpdatesBackgroundBrush" Color="#DCEBFA" />
            <SolidColorBrush x:Key="StatInstalledBrush" Color="#0E8A16" />
            <SolidColorBrush x:Key="StatInstalledBackgroundBrush" Color="#DFF6DD" />
            <SolidColorBrush x:Key="StatPendingBrush" Color="#9D5D00" />
            <SolidColorBrush x:Key="StatPendingBackgroundBrush" Color="#FFF4CE" />
            <SolidColorBrush x:Key="StatUnknownBrush" Color="#C42B1C" />
            <SolidColorBrush x:Key="StatUnknownBackgroundBrush" Color="#FDE7E9" />

            <Style x:Key="SectionTitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,6" />
            </Style>

            <Style x:Key="SectionSubtitleTextBlockStyle" TargetType="TextBlock">
                <Setter Property="Opacity" Value="0.72" />
                <Setter Property="Margin" Value="0,0,0,14" />
            </Style>

            <Style x:Key="FieldLabelTextBlockStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Opacity" Value="0.72" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="MinWidth" Value="120" />
            </Style>

            <Style x:Key="GridCellTextStyle" TargetType="TextBlock">
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="Background" Value="{DynamicResource ControlFillColorInputBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="MinHeight" Value="42" />
                <Setter Property="Padding" Value="12,0,36,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
            </Style>

            <Style x:Key="FluentComboBoxItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Style.Triggers>
                    <Trigger Property="IsHighlighted" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FluentTextBoxStyle" TargetType="ui:TextBox">
                <Setter Property="MinHeight" Value="42" />
                <Setter Property="Padding" Value="12,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="FluentReadOnlyTextBoxStyle" TargetType="ui:TextBox" BasedOn="{StaticResource FluentTextBoxStyle}">
                <Setter Property="IsReadOnly" Value="True" />
            </Style>

            <Style x:Key="LinkChipButtonStyle" TargetType="ui:Button">
                <Setter Property="Appearance" Value="Secondary" />
                <Setter Property="MinHeight" Value="38" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Margin" Value="0,0,10,10" />
                <Setter Property="Padding" Value="14,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

